# Weekly report workflow — COPY THIS FILE MANUALLY.
#
# The Claude GitHub App cannot create files under .github/workflows/, so this
# lives at the repo root. To enable it:
#   1. Copy this file to .github/workflows/weekly-report.yml
#   2. Commit and push it yourself.
#
# It runs Sundays, generates reports/YYYY-MM-DD.md via one cheap Anthropic call,
# and commits the report back to the repo. Needs only the ANTHROPIC_API_KEY
# secret you already use for the daily short.

name: weekly-report

on:
  schedule:
    - cron: "0 18 * * 0"   # Sundays 18:00 UTC
  workflow_dispatch: {}

permissions:
  contents: write

jobs:
  report:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install deps
        run: pip install -r requirements.txt

      - name: Generate weekly report
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: python src/weekly_report.py

      - name: Commit report
        run: |
          git config user.name "stoic-bot"
          git config user.email "bot@users.noreply.github.com"
          git add reports/
          git diff --staged --quiet || git commit -m "weekly-report: $(date -u +%F)"
          git push
